    </mxCell>

    <mxCell id="seg-exec" value="&lt;b&gt;Segmentation Executor&lt;/b&gt;&lt;br&gt;Sequential step runner&lt;br&gt;Steps driven by DB config&lt;br&gt;Decoupled from main flow"
      style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;"
      vertex="1" parent="svc-grp">
      <mxGeometry x="260" y="175" width="200" height="80" as="geometry" />
    </mxCell>

    <mxCell id="state-box" value="&lt;b&gt;State Machine Transitions (in code):&lt;/b&gt;&lt;br&gt;pending → scraping → scraped&lt;br&gt;→ identifying → identified&lt;br&gt;→ [hitl_post_identification?] awaiting_hitl_identification&lt;br&gt;→ generating_garment_summary → garment_summary_generated&lt;br&gt;→ generating_vton → vton_generated&lt;br&gt;→ segmenting → segmented&lt;br&gt;→ [hitl_post_segmentation?] awaiting_hitl_segmentation&lt;br&gt;→ placement → completed&lt;br&gt;→ failed / cancelled (from any state)"
      style="text;html=1;strokeColor=#82b366;fillColor=#f0fff0;align=left;verticalAlign=middle;spacingLeft=8;fontSize=10;rounded=1;"
      vertex="1" parent="svc-grp">
