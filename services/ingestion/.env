BG_REMOVAL_PROVIDER=clipdrop

# LLM settings
LLM_PRIMARY=gemini
LLM_FALLBACK=openai
LLM_JSON_STRICT=true

# Soft rate limits (enforced in app)
MAX_CONCURRENCY_GLOBAL=8
MAX_CONCURRENCY_PER_DOMAIN=2

# Feature flags
ENABLE_PLAYWRIGHT_FALLBACK=true
ENABLE_MULTIMODAL_ENRICHMENT=true
ENABLE_YOLO_CORROBORATION=false

LANGGRAPH_CHECKPOINT_TABLE=ingestion_job_state
LANGGRAPH_ORCHESTRATOR_QUEUE=ingestion-orchestrator

ENABLE_GHOST_BACK_VIEW=false
